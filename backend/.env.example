# MongoDB (Atlas or local)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/agricredit?retryWrites=true&w=majority"

# Server
PORT=4000
NODE_ENV=development

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d

# --- M-Pesa (DEMO / HACKATHON ONLY — not for production)
# Use sandbox + Postman-style collections for demos only. Replace with live credentials
# and compliance review before any real-money deployment.
# Ethiopia sandbox (apisandbox.safaricom.et): v1 token + B2C v2 + STK v3.
# Falls back to simulated success if calls fail or vars are missing.
MPESA_BASE_URL=https://apisandbox.safaricom.et
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Short code / till (PartyA on B2C, BusinessShortCode on STK)
MPESA_SHORTCODE=

# STK Push: Lipa Na M-Pesa Online passkey (from portal) — used to build Password + Timestamp
MPESA_PASSKEY=

# B2C: API user initiator name + encrypted SecurityCredential from developer portal
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Callbacks (use https://webhook.site/... or your deployed URL for sandbox demos)
MPESA_CALLBACK_URL=https://example.com/mpesa-callback
# Optional overrides if B2C and STK need different URLs:
# MPESA_RESULT_URL=
# MPESA_QUEUE_TIMEOUT_URL=
# MPESA_STK_CALLBACK_URL=

# Kenya Daraja instead: set MPESA_BASE_URL=https://sandbox.safaricom.co.ke (code switches token + API paths)
